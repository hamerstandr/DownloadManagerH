<Window x:Class="DownloadManagerH.Windows.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="clr-namespace:DownloadManagerH.Models" 
        xmlns:local1="clr-namespace:DownloadManagerH.Controls"
        Title="تنظیمات" Height="1000" Width="800" FlowDirection="RightToLeft" 
        ResizeMode="NoResize" WindowStartupLocation="CenterScreen">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <ScrollViewer VerticalScrollBarVisibility="Auto" Grid.Row="0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="0,0,0,10">
                    <TextBlock Text="تعداد بخش‌های موازی:" VerticalAlignment="Center" Width="170"/>
                    <local1:NumericUpDown x:Name="txtParts" Width="80" Min="1" Max="8"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Grid.Row="1" Margin="0,0,0,10">
                    <TextBlock Text="حداکثر دانلود همزمان:" VerticalAlignment="Center" Width="170"/>
                    <local1:NumericUpDown x:Name="numMaxConcurrent" Width="80" Min="1" Max="20" Value="{x:Static models:Settings.MaxConcurrentDownloadsLimit}"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Grid.Row="2" Margin="0,0,0,10">
                    <TextBlock Text="تعداد اتصالات موازی:" VerticalAlignment="Center" Width="170"/>
                    <local1:NumericUpDown x:Name="numConcurrentDownloads" Width="80" Min="1" Max="20" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Grid.Row="3" Margin="0,0,0,10">
                    <TextBlock Text="🐱‍💻 استارت‌آپ ویندوز:" VerticalAlignment="Center" Width="170"/>
                    <ToggleButton x:Name="toggleStartup" Width="50" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Grid.Row="4" Margin="0,0,0,10">
                    <TextBlock Text="📋 مانیتور کلیپ‌بورد:" VerticalAlignment="Center" Width="170"/>
                    <ToggleButton x:Name="toggleClipboard" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Grid.Row="5" Margin="0,0,0,10">
                    <TextBlock Text="📁 آدرس پیش‌فرض دانلود:" VerticalAlignment="Center" Width="170"/>
                    <TextBox x:Name="txtDefaultPath" Width="280" FlowDirection="LeftToRight"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Grid.Row="6" Margin="0,0,0,10">
                    <TextBlock Text="🎨 رنگ تم دکمه‌ها:" VerticalAlignment="Center" Width="170"/>
                    <local1:ColorPicker x:Name="colorPickerTheme" Width="120"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Grid.Row="7" Margin="0,0,0,10">
                    <TextBlock Text="افزودن مستقیم دانلودهای افزونه:" VerticalAlignment="Center" Width="170"/>
                    <ToggleButton x:Name="toggleAddDirect" Width="50"/>
                </StackPanel>
                
                <!-- انتخاب زبان -->
                <StackPanel Orientation="Horizontal" Grid.Row="8" Margin="0,0,0,10">
                    <TextBlock Text="🌐 زبان برنامه:" VerticalAlignment="Center" Width="170"/>
                    <ComboBox x:Name="cmbLanguage" Width="150" SelectionChanged="CmbLanguage_SelectionChanged">
                        <ComboBoxItem Content="فارسی (Persian)" Tag="fa"/>
                        <ComboBoxItem Content="العربية (Arabic)" Tag="ar"/>
                        <ComboBoxItem Content="English (انگلیسی)" Tag="en"/>
                    </ComboBox>
                </StackPanel>
                
                <Border Grid.Row="9" BorderBrush="#1976d2" BorderThickness="1" CornerRadius="6" Background="#f5faff" Margin="0,0,0,0" Padding="16" DockPanel.Dock="Bottom">
                    <StackPanel>
                        <TextBlock Text="نصب افزونه مرورگر" FontWeight="Bold" FontSize="16" Margin="0,0,0,8"/>
                        <TextBlock Text="برای دریافت لینک دانلود افزونه مناسب مرورگر خود، روی دکمه زیر کلیک کنید." Margin="0,0,0,8"/>
                        <StackPanel Orientation="Horizontal">
                            <Button  Width="180" Margin="0,0,10,0" Click="BtnDownloadChromeExtension_Click">
                                <Button.Content>
                                    <StackPanel Orientation="Horizontal">
                                        <Image Width="24" Height="24" Source="{StaticResource ChromeIcon}" Margin="0,0,8,0"/>
                                        <TextBlock Text="دانلود افزونه Chrome"/>
                                    </StackPanel>
                                </Button.Content>
                            </Button>
                            <Button Width="180" Margin="0,0,10,0" Click="BtnDownloadFirefoxExtension_Click">
                                <Button.Content>
                                    <StackPanel Orientation="Horizontal">
                                        <Image Width="24" Height="24" Source="{StaticResource FirefoxIcon}" Margin="0,0,8,0"/>
                                        <TextBlock Text="دانلود افزونه Firefox"/>
                                    </StackPanel>
                                </Button.Content>
                            </Button>
                            <Button Width="180" Click="BtnDownloadEdgeExtension_Click">
                                <Button.Content>
                                    <StackPanel Orientation="Horizontal">
                                        <Image Width="24" Height="24" Source="{StaticResource EdgeIcon}" Margin="0,0,8,0"/>
                                        <TextBlock Text="دانلود افزونه Edge"/>
                                    </StackPanel>
                                </Button.Content>
                            </Button>
                        </StackPanel>
                    </StackPanel>
                </Border>
                
                <!-- یکپارچگی با TrafficWatch -->
                <GroupBox Header="📊 یکپارچگی با TrafficWatch" Grid.Row="10" Margin="0,10,0,0" Padding="10">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <CheckBox x:Name="chkTrafficWatch" Content="نمایش اطلاعات در داشبورد TrafficWatch" IsChecked="True" VerticalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="20,0,0,0">
                            <TextBlock Text="پورت API:" VerticalAlignment="Center"/>
                            <TextBox x:Name="txtTrafficWatchPort" Width="80" Margin="10,0,0,0" Text="9090" VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock Text="پس از تغییر پورت، برنامه را مجدداً راه‌اندازی کنید" FontSize="10" Foreground="Gray" Margin="20,5,0,0"/>
                        <TextBlock Text="TrafficWatch یک داشبورد وب برای مانیتورینگ دانلودها است" FontSize="10" Foreground="Gray" Margin="20,2,0,0"/>
                    </StackPanel>
                </GroupBox>
            </Grid>
        </ScrollViewer>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0" Grid.Row="1" VerticalAlignment="Bottom">
            <Button Content="💾 ذخیره" Width="120" Margin="0,0,10,0" Click="BtnSave_Click" Background="#4caf50" Foreground="White"/>
            <Button Content="❌ انصراف" Width="120" Click="BtnCancel_Click" Background="#e57373" Foreground="White"/>
        </StackPanel>
        
    </Grid>
</Window> 