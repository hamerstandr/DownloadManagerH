<Window x:Class="DownloadManagerH.Windows.LogViewerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="نمایشگر لاگ‌ها - دانلود منجر حامد" 
        Height="600" Width="1000" 
        Background="#f7f7fa" 
        Icon="/icons8_chevron_down_480px.png" 
        FlowDirection="RightToLeft"
        WindowStartupLocation="CenterScreen">
    
    <Window.Resources>
        <!-- استایل‌های مخصوص نمایشگر لاگ -->
        <Style x:Key="LogLevelButtonStyle" TargetType="ToggleButton">
            <Setter Property="Margin" Value="5,0"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Background" Value="#e3e6f0"/>
            <Setter Property="BorderBrush" Value="#d1d3e2"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsChecked" Value="True">
                    <Setter Property="Background" Value="#4e73df"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#5a5c69"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="LogEntryStyle" TargetType="ListViewItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Margin" Value="0,1"/>
            <Setter Property="Padding" Value="5"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding Level}" Value="Error">
                    <Setter Property="Background" Value="#ffe6e6"/>
                    <Setter Property="BorderBrush" Value="#ff9999"/>
                    <Setter Property="BorderThickness" Value="1,0,0,0"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Level}" Value="Warning">
                    <Setter Property="Background" Value="#fff3cd"/>
                    <Setter Property="BorderBrush" Value="#ffc107"/>
                    <Setter Property="BorderThickness" Value="1,0,0,0"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Level}" Value="Info">
                    <Setter Property="Background" Value="#e7f3ff"/>
                    <Setter Property="BorderBrush" Value="#007bff"/>
                    <Setter Property="BorderThickness" Value="1,0,0,0"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Level}" Value="Debug">
                    <Setter Property="Background" Value="#f8f9fa"/>
                    <Setter Property="BorderBrush" Value="#6c757d"/>
                    <Setter Property="BorderThickness" Value="1,0,0,0"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- نوار ابزار فیلتر -->
        <Border Grid.Row="0" Background="White" BorderBrush="#d1d3e2" BorderThickness="1" CornerRadius="5" Padding="10" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- فیلتر سطح لاگ -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="سطح لاگ:" VerticalAlignment="Center" Margin="0,0,10,0" FontWeight="Bold"/>
                    <ToggleButton x:Name="btnDebug" Content="Debug" Style="{StaticResource LogLevelButtonStyle}" IsChecked="True" Click="LogLevelFilter_Click"/>
                    <ToggleButton x:Name="btnInfo" Content="Info" Style="{StaticResource LogLevelButtonStyle}" IsChecked="True" Click="LogLevelFilter_Click"/>
                    <ToggleButton x:Name="btnWarning" Content="Warning" Style="{StaticResource LogLevelButtonStyle}" IsChecked="True" Click="LogLevelFilter_Click"/>
                    <ToggleButton x:Name="btnError" Content="Error" Style="{StaticResource LogLevelButtonStyle}" IsChecked="True" Click="LogLevelFilter_Click"/>
                </StackPanel>

                <!-- جستجو -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="جستجو:" VerticalAlignment="Center" Margin="20,0,10,0" FontWeight="Bold"/>
                    <TextBox x:Name="txtSearch" Width="200" Height="30" VerticalContentAlignment="Center" 
                             TextChanged="TxtSearch_TextChanged" 
                             ToolTip="جستجو در متن لاگ‌ها"/>
                    <Button x:Name="btnClearSearch" Content="پاک کردن" Margin="5,0,0,0" Padding="10,5" Click="BtnClearSearch_Click"/>
                </StackPanel>

                <!-- کنترل‌های تاریخ -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="از تاریخ:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                    <DatePicker x:Name="dpFromDate" Width="120" SelectedDateChanged="DateFilter_Changed"/>
                    <TextBlock Text="تا تاریخ:" VerticalAlignment="Center" Margin="10,0,5,0"/>
                    <DatePicker x:Name="dpToDate" Width="120" SelectedDateChanged="DateFilter_Changed"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- نوار ابزار عملیات -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
            <Button x:Name="btnRefresh" Content="🔄 بروزرسانی" Padding="10,5" Margin="0,0,10,0" Click="BtnRefresh_Click" ToolTip="بروزرسانی لاگ‌ها"/>
            <Button x:Name="btnClear" Content="🗑️ پاک کردن" Padding="10,5" Margin="0,0,10,0" Click="BtnClear_Click" ToolTip="پاک کردن لاگ‌های نمایش داده شده"/>
            <Button x:Name="btnExport" Content="📤 صادرات" Padding="10,5" Margin="0,0,10,0" Click="BtnExport_Click" ToolTip="صادرات لاگ‌ها به فایل"/>
            <Button x:Name="btnAutoScroll" Content="📜 پیمایش خودکار" Padding="10,5" Margin="0,0,10,0" Click="BtnAutoScroll_Click" ToolTip="فعال/غیرفعال کردن پیمایش خودکار"/>
            <Separator Margin="10,0"/>
            <TextBlock Text="تعداد لاگ‌ها:" VerticalAlignment="Center" Margin="0,0,5,0" FontWeight="Bold"/>
            <TextBlock x:Name="lblLogCount" Text="0" VerticalAlignment="Center" FontWeight="Bold" Foreground="#007bff"/>
        </StackPanel>

        <!-- لیست لاگ‌ها -->
        <ListView x:Name="lvLogs" Grid.Row="2" 
                  ScrollViewer.HorizontalScrollBarVisibility="Auto"
                  ScrollViewer.VerticalScrollBarVisibility="Auto"
                  ItemContainerStyle="{StaticResource LogEntryStyle}"
                  SelectionMode="Extended"
                  MouseDoubleClick="LvLogs_MouseDoubleClick">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="زمان" Width="150" DisplayMemberBinding="{Binding Timestamp, StringFormat=yyyy-MM-dd HH:mm:ss.fff}"/>
                    <GridViewColumn Header="سطح" Width="80">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <Border CornerRadius="3" Padding="5,2" HorizontalAlignment="Center">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Level}" Value="Error">
                                                    <Setter Property="Background" Value="#dc3545"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Level}" Value="Warning">
                                                    <Setter Property="Background" Value="#ffc107"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Level}" Value="Info">
                                                    <Setter Property="Background" Value="#007bff"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Level}" Value="Debug">
                                                    <Setter Property="Background" Value="#6c757d"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="{Binding Level}" Foreground="White" FontWeight="Bold" FontSize="10"/>
                                </Border>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Header="دسته‌بندی" Width="100" DisplayMemberBinding="{Binding Category}"/>
                    <GridViewColumn Header="پیام" Width="400" DisplayMemberBinding="{Binding Message}"/>
                    <GridViewColumn Header="زمینه" Width="200" DisplayMemberBinding="{Binding Context}"/>
                </GridView>
            </ListView.View>
        </ListView>

        <!-- نوار وضعیت -->
        <StatusBar Grid.Row="3" Height="30" Background="#f8f9fa" BorderBrush="#d1d3e2" BorderThickness="0,1,0,0">
            <StatusBarItem>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="آخرین بروزرسانی:" Margin="0,0,5,0"/>
                    <TextBlock x:Name="lblLastUpdate" Text="هرگز" FontWeight="Bold"/>
                </StackPanel>
            </StatusBarItem>
            <StatusBarItem HorizontalAlignment="Right">
                <StackPanel Orientation="Horizontal">
                    <TextBlock x:Name="lblAutoScrollStatus" Text="پیمایش خودکار: فعال" Margin="0,0,10,0"/>
                    <TextBlock x:Name="lblFilterStatus" Text="فیلتر: همه" FontWeight="Bold"/>
                </StackPanel>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>