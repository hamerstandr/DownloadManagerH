<Window x:Class="DownloadManagerH.Windows.Dialog.FileConflictDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="تعارض فایل" Height="280" Width="500" 
        ResizeMode="NoResize" WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI"
        Icon="{StaticResource WarningIcon}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- عنوان -->
        <TextBlock x:Name="txtTitle" FontSize="18" FontWeight="Bold" Margin="0,0,0,10"/>
        
        <!-- پیام -->
        <TextBlock x:Name="lblMessage" Grid.Row="1" FontSize="14" TextWrapping="Wrap" Margin="0,0,0,20"/>
        
        <!-- آیکون -->
        <Image Grid.Row="2" Width="48" Height="48" Source="{StaticResource WarningIcon}" 
               HorizontalAlignment="Left" VerticalAlignment="Top"/>
        
        <!-- دکمه‌ها -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button x:Name="btnOverwrite" ToolTip="جایگزینی فایل"  Margin="0,0,10,0" Click="BtnOverwrite_Click" Style="{StaticResource ToolbarButtonStyle}">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Image Width="20" Height="20" Source="{StaticResource overIcon}"/>
                    <TextBlock Text="جایگزینی (Overwrite)" />
                </StackPanel>
            </Button>
            <Button x:Name="btnRename" ToolTip="تغییر نام" Width="120" Margin="0,0,10,0" Click="BtnRename_Click" Style="{StaticResource ToolbarButtonStyle}">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Image Width="20" Height="20" Source="{StaticResource EditIcon}"/>
                    <TextBlock Text="تغییر نام" Margin="5,0,0,0"/>
                </StackPanel>
            </Button>
            <Button x:Name="btnCancel" ToolTip="انصراف" Width="120" Click="BtnCancel_Click" Style="{StaticResource ToolbarButtonStyle}">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Image Width="20" Height="20" Source="{StaticResource CrossIcon}"/>
                    <TextBlock Text="انصراف" Margin="5,0,0,0"/>
                </StackPanel>
            </Button>
        </StackPanel>
    </Grid>
</Window>
