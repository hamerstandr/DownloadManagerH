<Window x:Class="DownloadManagerH.Windows.Dialog.CustomMessageBox"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="پیام" Height="350" Width="500" 
        ResizeMode="NoResize" WindowStartupLocation="CenterScreen" FlowDirection="RightToLeft"
        Icon="/icons8_chevron_down2.ico">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <!-- آیکون و عنوان -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,15">
            <Image x:Name="imgIcon" Width="32" Height="32" Margin="0,0,10,0"/>
            <TextBlock x:Name="txtTitle" FontSize="18" FontWeight="Bold" VerticalAlignment="Center"/>
        </StackPanel>
        <!-- پیام اصلی -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,0,0,10">
            <TextBlock x:Name="lblMessage" FontSize="14" TextWrapping="Wrap"/>
        </ScrollViewer>
        <!-- جزئیات خطا (قابل انتخاب) -->
        <ScrollViewer Grid.Row="2" x:Name="scrollDetails" VerticalScrollBarVisibility="Auto" Margin="0,5,5,0" Visibility="Collapsed" MaxHeight="100">
            <TextBox x:Name="txtDetails" FontSize="12" TextWrapping="Wrap" Foreground="#666" FontFamily="Consolas" 
                     Background="Transparent" BorderThickness="0" IsReadOnly="True" AcceptsReturn="True" VerticalScrollBarVisibility="Auto"/>
        </ScrollViewer>
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button x:Name="btnOk" Width="90" Margin="0,0,10,0" Click="BtnOk_Click" Style="{StaticResource ToolbarButtonStyle}">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Image Width="20" Height="20" Source="{StaticResource CheckIcon}"/>
                    <TextBlock Text="تایید" Margin="5,0,0,0"/>
                </StackPanel>
            </Button>
            <Button x:Name="btnCancel" Width="90" Click="BtnCancel_Click" Style="{StaticResource ToolbarButtonStyle}" Visibility="Collapsed">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Image Width="20" Height="20" Source="{StaticResource CrossIcon}"/>
                    <TextBlock Text="انصراف" Margin="5,0,0,0"/>
                </StackPanel>
            </Button>
            <Button x:Name="btnYes" Width="90" Margin="0,0,10,0" Click="BtnYes_Click" Style="{StaticResource ToolbarButtonStyle}" Visibility="Collapsed">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Image Width="20" Height="20" Source="{StaticResource CheckIcon}"/>
                    <TextBlock Text="بله" Margin="5,0,0,0"/>
                </StackPanel>
            </Button>
            <Button x:Name="btnNo" Width="90" Click="BtnNo_Click" Style="{StaticResource ToolbarButtonStyle}" Visibility="Collapsed">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Image Width="20" Height="20" Source="{StaticResource CrossIcon}"/>
                    <TextBlock Text="خیر" Margin="5,0,0,0"/>
                </StackPanel>
            </Button>
        </StackPanel>
    </Grid>
</Window> 