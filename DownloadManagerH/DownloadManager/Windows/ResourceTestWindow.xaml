<Window x:Class="DownloadManagerH.Windows.ResourceTestWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="تست‌های عملکرد مدیریت منابع" Height="600" Width="800"
        WindowStartupLocation="CenterScreen" FlowDirection="RightToLeft">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" Text="تست‌های عملکرد مدیریت منابع" 
                   FontSize="18" FontWeight="Bold" Margin="0,0,0,10"
                   HorizontalAlignment="Center"/>

        <!-- Test Results -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Name="TestResultsPanel">
                <TextBlock Text="برای شروع تست‌ها، روی دکمه 'اجرای تست‌ها' کلیک کنید."
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           FontSize="14" Foreground="Gray"/>
            </StackPanel>
        </ScrollViewer>

        <!-- Progress Bar -->
        <ProgressBar Grid.Row="2" Name="TestProgressBar" Height="20" Margin="0,10"
                     Visibility="Collapsed"/>

        <!-- Buttons -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
            <Button Name="OpenLoger" Content="🧪 مشاهده لاگ ها" 
        Width="120" Height="35" Margin="5" Click="OpenLoger_Click"/>
            <Button Name="RunTestsButton" Content="🧪 اجرای تست‌ها" 
                    Width="120" Height="35" Margin="5" Click="RunTestsButton_Click"/>
            <Button Name="ClearButton" Content="🗑️ پاک کردن" 
                    Width="120" Height="35" Margin="5" Click="ClearButton_Click"/>
            <Button Name="CloseButton" Content="❌ بستن" 
                    Width="120" Height="35" Margin="5" Click="CloseButton_Click"/>
        </StackPanel>
    </Grid>
</Window>