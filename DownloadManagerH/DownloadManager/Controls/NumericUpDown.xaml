<UserControl x:Class="DownloadManagerH.Controls.NumericUpDown"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Height="48" Width="120">
    <Border BorderBrush="#1976d2" BorderThickness="1" CornerRadius="4" Background="White">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="32"/>
            </Grid.ColumnDefinitions>
            
            <TextBox x:Name="txtValue" Text="0" HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch" FontSize="16" BorderThickness="0" Margin="0,0,0,0" Padding="5,5,5,0"/>
            <Grid  Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Button Padding="0" Margin="0" x:Name="btnUp" Click="BtnUp_Click">
                    <TextBlock Text="▲" Foreground="White" />
                </Button>
                <Button Padding="0" Margin="0" Grid.Row="1" x:Name="btnDown" Click="BtnDown_Click">
                    <TextBlock Text="▼"  Foreground="White" />
                </Button>
            </Grid>
            
        </Grid>
    </Border>
</UserControl> 