<UserControl x:Class="DownloadManagerH.Controls.ColorPicker"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Height="30" Width="120">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        
        <!-- نمایش رنگ فعلی -->
        <Border x:Name="borderColorPreview" 
                Grid.Column="0" 
                BorderBrush="Gray" 
                BorderThickness="1" 
                CornerRadius="3"
                Margin="0,0,5,0">
            <Border.Background>
                <SolidColorBrush x:Name="brushPreview" Color="#FF007ACC"/>
            </Border.Background>
        </Border>
        
        <!-- دکمه انتخاب رنگ -->
        <Button x:Name="btnSelectColor" 
                Grid.Column="1" 
                Content="🎨" 
                Width="30" 
                Click="BtnSelectColor_Click"
                ToolTip="انتخاب رنگ"/>
        
        <!-- TextBox مخفی برای ذخیره مقدار هگز -->
        <TextBox x:Name="txtHexColor" 
                 Visibility="Collapsed" 
                 Text="#FF007ACC"/>
    </Grid>
</UserControl>
