<Application x:Class="DownloadManagerH.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:tb="http://www.hardcodet.net/taskbar"
             xmlns:models="clr-namespace:DownloadManagerH.Models"
             StartupUri="Windows/MainWindow.xaml">
    <Application.Resources>
        
        <ResourceDictionary>

            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="res/ModernTheme.xaml" />
                <ResourceDictionary Source="res/ColorfulIcons.xaml" />
                <!-- برای تم کلاسیک: <ResourceDictionary Source="res/ClassicTheme.xaml"/> -->
            </ResourceDictionary.MergedDictionaries>
            <tb:TaskbarIcon x:Key="TrayIcon"
                            IconSource="/icons8_chevron_down2.ico"
                            ToolTipText="دانلود منجر حامد">
                <tb:TaskbarIcon.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="مشاهده/مخفی" x:Name="MenuShowHide"/>
                        <MenuItem Header="تنظیمات" x:Name="MenuSettings"/>
                        <Separator/>
                        <MenuItem Header="درباره برنامه..." x:Name="MenuAbuot"/>
                        <Separator/>
                        <MenuItem Header="خروج" x:Name="MenuExit"/>
                    </ContextMenu>
                </tb:TaskbarIcon.ContextMenu>
            </tb:TaskbarIcon>
            <models:GroupColorConverter x:Key="GroupColorConverter"/>
            <models:StatusColorConverter x:Key="StatusColorConverter"/>
            <models:CompletedOnlyConverter x:Key="CompletedOnlyConverter" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
